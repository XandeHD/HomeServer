@implements IDisposable

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">@L.T("nav.home")</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="finance">
                <span class="bi bi-wallet2" aria-hidden="true"></span> @L.T("nav.finance")
            </NavLink>
        </div>
    </nav>
</div>

@code {
    protected override void OnInitialized()
    {
        L.OnLanguageChanged += OnLangChanged;
    }
    private void OnLangChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() { L.OnLanguageChanged -= OnLangChanged; }
}
