@page "/finance/buyorder/{Id:int}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@implements IDisposable
@using Classes.Models
@using Data.Models
@using Microsoft.EntityFrameworkCore

@inject IDbContextFactory<DataContext> DbFactory

<PageTitle>Buy Order #@Id</PageTitle>

<div class="card border-0 shadow-sm bg-white rounded p-4 mb-4">
    <div class="row align-items-center">
        <div class="col-md-6">
            <span class="text-uppercase text-secondary small tracking-wider fw-bold">@L.T("finance.buyordersinfo.orderDetails")</span>
            <h1 class="h2 text-dark fw-bold mb-1">@L.T("finance.buyordersinfo.orderDetails") #@Id</h1>
            <p class="text-muted small mb-md-0"><i class="bi bi-calendar3 me-1"></i> @(orderHeader?.Date.ToString("dd-MM-yyyy") ?? L.T("common.loading"))</p>
        </div>

        <div class="col-md-6 text-md-end mt-3 mt-md-0">
            <div class="d-inline-block text-start me-4">
                <span class="text-muted small d-block">@L.T("finance.buyordersinfo.market")</span>
                <span class="fs-5 fw-semibold text-secondary"><i class="bi bi-shop me-1"></i> @(orderHeader?.Market ?? "---")</span>
            </div>
            <div class="d-inline-block text-start border-start ps-4">
                <span class="text-muted small d-block">@L.T("common.total")</span>
                <span class="fs-4 fw-bold text-primary">€@(orderHeader?.Total.ToString("F2") ?? "0.00")</span>
            </div>
        </div>
    </div>
</div>

@if (orderLines == null)
{
    <p><em>@L.T("finance.buyordersinfo.loadingLines")</em></p>
}
else if (!orderLines.Any())
{
    <p><em>@L.T("finance.buyordersinfo.noProducts")</em></p>
}
else
{
    <table class="table table-hover align-middle border-top border-light shadow-sm bg-white rounded">
        <thead class="table-light text-secondary small text-uppercase tracking-wider">
            <tr>
                <th class="ps-3">@L.T("common.description")</th>
                <th class="text-center" style="width: 120px;">@L.T("finance.buyordersinfo.quantity")</th>
                <th class="text-center" style="width: 100px;">@L.T("finance.buyordersinfo.unit")</th>
                <th class="text-end" style="width: 120px;">@L.T("finance.expenses.price")</th>
                <th class="text-end pe-3" style="width: 150px;">@L.T("finance.buyordersinfo.lineTotal")</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var line in orderLines)
            {
                <tr>
                    <td class="ps-3 fw-semibold text-dark">@line.Description</td>
                    <td class="text-center text-secondary fw-medium">@line.Quantity</td>
                    <td class="text-center text-muted small">@line.Unit</td>
                    <td class="text-end text-secondary">@line.Price.ToString("C")</td>
                    <td class="text-end fw-bold text-primary pe-3">
                        @((line.Price * line.Quantity).ToString("C"))
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    protected override void OnInitialized()
    {
        L.OnLanguageChanged += OnLangChanged;
    }
    private void OnLangChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() { L.OnLanguageChanged -= OnLangChanged; }

    [Parameter]
    public int Id { get; set; }

    private BuyOrder? orderHeader;

    private List<BuyOrderLine>? orderLines;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
           
            orderHeader = await db.BuyOrders
                .FirstOrDefaultAsync(o => o.Id == Id);

            // Fetch explicitly using raw SQL to see if it bypasses the alias issue
            // If SQLite expects 'id' or 'ID' instead of 'Id', we bypass the EF Core LINQ translator mapping
            orderLines = await db.BuyOrderLines
                .Where(l => l.BuyOrderId == Id)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Direct Query Error: {ex.Message}");
            orderLines = new List<BuyOrderLine>(); // Fallback empty to prevent loop crashing
        }
    }
}