@page "/finance"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using System.Globalization
@using System.Security.Claims
@using SalaryModel = HomeServer.Data.Models.Salary
@inject IDbContextFactory<DataContext> DbFactory

<PageTitle>Finance Dashboard</PageTitle>

<div class="container-fluid px-0">
    @* Dashboard Header *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h4 text-dark fw-semibold mb-0">Expense Analytics</h1>
            <p class="text-muted small mb-0">Interactive tracking and filtering.</p>
        </div>
    </div>


    @if (!isLoading)
    {
        @* Dynamic KPI Cards *@
        <div class="row g-3 mb-2">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-3 h-100 border-start border-4 border-primary">
                    <div class="card-body">
                        <h6 class="text-muted small text-uppercase fw-bold mb-2">Total Period Spent</h6>
                        <h3 class="fw-bold text-dark mb-0">€@periodTotal.ToString("F2")</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-3 h-100 border-start border-4 border-info">
                    <div class="card-body">
                        <h6 class="text-muted small text-uppercase fw-bold mb-2">
                            @(viewMode == ViewScope.Monthly ? "Daily Average" : "Monthly Average")
                        </h6>
                        <h3 class="fw-bold text-dark mb-0">€@periodAverage.ToString("F2")</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-3 h-100 border-start border-4 border-success">
                    <div class="card-body">
                        <h6 class="text-muted small text-uppercase fw-bold mb-2">
                            @(selectedCategory == "All" ? "Top Category" : "Top Place")
                        </h6>
                        <h3 class="fw-bold text-success mb-0 text-truncate" title="@dynamicTopMetric">
                            @(string.IsNullOrEmpty(dynamicTopMetric) ? "---" : dynamicTopMetric)
                        </h3>
                    </div>
                </div>
            </div>
        </div>
    }


    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="text-muted mt-2 small fw-medium">Crunching the numbers...</p>
        </div>
    }
    else
    {
        @* Filter Toolbar *@
        <div class="card border-0 shadow-sm rounded-3 mb-2 bg-white">
            <div class="card-body p-3 d-flex flex-wrap gap-3 align-items-center">

                @* View Mode Selector *@
                <div class="btn-group btn-group-sm border rounded-3 p-0.5 bg-light shadow-sm" role="group">
                    <button type="button" class="btn btn-sm py-1.5 px-3 border-0 rounded-2 fw-medium @(viewMode == ViewScope.Monthly ? "btn-primary shadow-sm" : "text-secondary")"
                            @onclick="() => SetViewMode(ViewScope.Monthly)">
                        Month
                    </button>
                    <button type="button" class="btn btn-sm py-1.5 px-3 border-0 rounded-2 fw-medium @(viewMode == ViewScope.Yearly ? "btn-primary shadow-sm" : "text-secondary")"
                            @onclick="() => SetViewMode(ViewScope.Yearly)">
                        Year
                    </button>
                </div>

                @* Conditional Date Pickers *@
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-calendar-month text-primary"></i>
                    @if (viewMode == ViewScope.Monthly)
                    {
                        <input type="month" class="form-control form-control-sm border-light shadow-none fw-medium bg-light"
                               value="@targetMonthString" @onchange="OnMonthChanged" style="cursor: pointer; width: 160px;" />
                    }
                    else
                    {
                        <select class="form-select form-select-sm border-light shadow-none fw-medium bg-light"
                                value="@targetYear" @onchange="OnYearChanged" style="cursor: pointer; width: 110px;">
                            @for (int y = DateTime.Now.Year - 5; y <= DateTime.Now.Year + 5; y++)
                            {
                                <option value="@y">@y</option>
                            }
                        </select>
                    }
                </div>

                @* Category Filter *@
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-tag text-primary"></i>
                    <select class="form-select form-select-sm border-light shadow-none fw-medium bg-light"
                            value="@selectedCategory" @onchange="OnCategoryChanged" style="cursor: pointer; min-width: 150px;">
                        <option value="All">All Categories</option>
                        @foreach (var cat in availableCategories)
                        {
                            <option value="@cat">@cat</option>
                        }
                    </select>
                </div>

                @if (selectedCategory != "All" || isCurrentPeriod == false)
                {
                    <div class="ms-auto">
                        <button class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1" @onclick="ResetFilters">
                            <i class="bi bi-arrow-counterclockwise"></i> <span class="small">Reset</span>
                        </button>
                    </div>
                }
            </div>
        </div>

        @* Upward-Growing Grid Chart *@
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h6 class="fw-bold text-dark mb-0">
                        @(viewMode == ViewScope.Monthly ? $"Daily Breakdown ({currentDate.ToString("MMMM yyyy", CultureInfo.InvariantCulture)})" : $"Monthly Breakdown ({targetYear})")
                    </h6>
                    <div class="d-flex gap-2">
                        @if (selectedCategory == "All" && currentActiveSalaryLimit > 0)
                        {
                            <span class="badge bg-danger-subtle text-danger border small fw-normal">
                                Active Income Cap: €@currentActiveSalaryLimit.ToString("F2")
                            </span>
                        }
                        <span class="badge bg-light text-dark border small fw-normal">
                            Max Peak Volume: €@maxChartSpend.ToString("F2")
                        </span>
                    </div>
                </div>

                @if (periodTotal == 0 && !chartData.Any())
                {
                    <div class="d-flex flex-column align-items-center justify-content-center py-5 text-muted">
                        <i class="bi bi-inbox fs-1 mb-2 opacity-50"></i>
                        <p class="mb-0 small fw-medium">No records found for this filter combination.</p>
                    </div>
                }
                else
                {
                    @* Content Container with relative positioning to absolute-plot the Income Line *@
                    <div class="position-relative" style="height: 240px; margin-top: 20px;">

                        @* THE RED INCOME LINE BLOCK *@
                        @if (selectedCategory == "All" && currentActiveSalaryLimit > 0 && maxChartSpend > 0)
                        {
                            @* Calculate the dynamic vertical position matching Blazor's calculation logic *@
                            double boost = 0.3;
                            double calculatedLineHeight = ((currentActiveSalaryLimit / maxChartSpend) * (1 - boost) + boost) * 85;

                            @* Fallback/cap safety to prevent line from flying out of the chart zone *@
                            if (calculatedLineHeight > 100) { calculatedLineHeight = 100; }
                            if (calculatedLineHeight < 0) { calculatedLineHeight = 0; }

                            <div style="position: absolute; left: 0; right: 0; bottom: calc(@(calculatedLineHeight.ToString("F2", CultureInfo.InvariantCulture))% + 20px); z-index: 10; border-top: 2px dashed #dc3545; pointer-events: none; transition: bottom 0.4s ease;">
                                <span class="badge bg-danger text-white rounded-1 shadow-sm px-1.5 py-0.5" style="position: absolute; right: 0; top: -10px; font-size: 0.65rem; font-family: monospace;">
                                    Income: €@currentActiveSalaryLimit.ToString("0")
                                </span>
                            </div>
                        }

                        @* CSS Grid Container *@
                        <div class="chart-grid-container" style="grid-template-columns: repeat(@totalBars, 1fr); gap: 3px; height: 100%;">
                            @for (int index = 1; index <= totalBars; index++)
                            {
                                var segmentTotal = chartData.ContainsKey(index) ? chartData[index] : 0;
                                var absTotal = Math.Abs(segmentTotal);

                                double boost = 0.3;
                                var finalHeight = 0.0;

                                if (absTotal > 0)
                                {
                                    finalHeight = ((absTotal / maxChartSpend) * (1 - boost) + boost) * 85;
                                }

                                var isCurrentSegment = (viewMode == ViewScope.Monthly)
                                ? (currentDate.Year == DateTime.Now.Year && currentDate.Month == DateTime.Now.Month && index == DateTime.Now.Day)
                                : (targetYear == DateTime.Now.Year && index == DateTime.Now.Month);

                                var isRefund = segmentTotal < 0;
                                bool isSavings = selectedCategory == "Savings";

                                <div class="chart-bar-wrapper">
                                    @if (absTotal > 0)
                                    {
                                        <span class="text-muted bar-value-text">
                                            @(isRefund ? "-" : "")@absTotal.ToString("0.#")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="bar-value-text text-transparent" style="color: transparent;">0</span>
                                    }

                                    <div class="chart-bar w-100 rounded-top @(isCurrentSegment ? "bg-primary" : (isRefund ? "bg-success" : (isSavings ? "bg-success" : "bg-info")))"
                                         style="height: @(finalHeight.ToString("F2", CultureInfo.InvariantCulture))%;
                                                            min-height: @(absTotal > 0 ? "4px" : "0");
                                                            transition: height 0.4s ease; opacity: 0.9;">
                                    </div>

                                    <div class="chart-label-text text-muted">
                                        @if (viewMode == ViewScope.Monthly)
                                        {
                                            @index
                                        }
                                        else
                                        {
                                            @CultureInfo.InvariantCulture.DateTimeFormat.GetAbbreviatedMonthName(index)
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mt-3 px-1">
                        <div class="d-flex gap-3">
                            <span class="text-muted small fw-medium"><i class="bi bi-square-fill text-red me-1"></i> Volume Spend</span>
                            <span class="text-muted small fw-medium"><i class="bi bi-square-fill text-success me-1"></i> Credit/Refund</span>
                            @if (selectedCategory == "All" && currentActiveSalaryLimit > 0)
                            {
                                <span class="text-muted small fw-medium"><i class="bi bi-dash text-danger fw-bold me-1"></i> Salary Cap Line</span>
                            }
                        </div>
                        <span class="text-muted small fw-medium"><i class="bi bi-square-fill text-primary me-1"></i> Current Period</span>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    private enum ViewScope { Monthly, Yearly }
    private ViewScope viewMode = ViewScope.Monthly;

    private DateTime currentDate = DateTime.Now;
    private bool isLoading = true;

    // Filters
    private string targetMonthString = DateTime.Now.ToString("yyyy-MM");
    private int targetYear = DateTime.Now.Year;
    private string selectedCategory = "All";
    private List<string> availableCategories = new();

    // UI Helpers
    private bool isCurrentPeriod => viewMode == ViewScope.Monthly
        ? (currentDate.Year == DateTime.Now.Year && currentDate.Month == DateTime.Now.Month)
        : (targetYear == DateTime.Now.Year);

    private int totalBars => viewMode == ViewScope.Monthly
        ? DateTime.DaysInMonth(currentDate.Year, currentDate.Month)
        : 12;

    private Dictionary<int, float> chartData = new();
    private float maxChartSpend = 0;
    private float periodTotal = 0;
    private float periodAverage = 0;
    private string dynamicTopMetric = "";

    // Line Calculation Storage
    private float currentActiveSalaryLimit = 0;

    // NOVO: Armazena os IDs dos utilizadores permitidos (do próprio ou do grupo inteiro)
    private List<int> targetUserIds = new();

    protected override async Task OnInitializedAsync()
    {
        await DetermineTargetUsersAsync();
        await LoadAvailableCategories();
        await LoadDashboardData();
    }

    private async Task DetermineTargetUsersAsync()
    {
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            var user = authState.User;

            if (user.Identity?.IsAuthenticated == true)
            {
                var userIdClaim = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

                if (int.TryParse(userIdClaim, out int userId))
                {
                    using var db = await DbFactory.CreateDbContextAsync();

                    // 1. Vai à base de dados descobrir se o utilizador atual pertence a um grupo
                    var currentGroupAssignment = await db.GroupUsers
                        .AsNoTracking()
                        .FirstOrDefaultAsync(gu => gu.UserId == userId);

                    if (currentGroupAssignment != null)
                    {
                        // 2. Se pertence a um grupo, vai buscar todos os UserIds que partilham esse GroupId
                        targetUserIds = await db.GroupUsers
                            .AsNoTracking()
                            .Where(gu => gu.GroupId == currentGroupAssignment.GroupId)
                            .Select(gu => gu.UserId)
                            .ToListAsync();
                    }
                    else
                    {
                        // 3. Se não tem grupo, carrega apenas o seu próprio ID
                        targetUserIds = new List<int> { userId };
                    }
                }
            }
        }
    }

    private async Task LoadAvailableCategories()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        availableCategories = await db.Expenses
            .AsNoTracking()
            .Where(e => targetUserIds.Contains(e.UserId)) // Apenas as categorias geradas pelo utilizador/grupo
            .Select(e => e.Category)
            .Distinct()
            .Where(c => !string.IsNullOrEmpty(c))
            .OrderBy(c => c)
            .ToListAsync();
    }

    private async Task SetViewMode(ViewScope mode)
    {
        if (viewMode == mode) return;
        viewMode = mode;
        await LoadDashboardData();
    }

    private async Task OnMonthChanged(ChangeEventArgs e)
    {
        if (e.Value is string monthStr && !string.IsNullOrWhiteSpace(monthStr))
        {
            if (DateTime.TryParseExact(monthStr, "yyyy-MM", CultureInfo.InvariantCulture, DateTimeStyles.None, out var parsedDate))
            {
                targetMonthString = monthStr;
                currentDate = parsedDate;
                targetYear = parsedDate.Year;
                await LoadDashboardData();
            }
        }
    }

    private async Task OnYearChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int year))
        {
            targetYear = year;
            currentDate = new DateTime(targetYear, currentDate.Month, 1);
            await LoadDashboardData();
        }
    }

    private async Task OnCategoryChanged(ChangeEventArgs e)
    {
        selectedCategory = e.Value?.ToString() ?? "All";
        await LoadDashboardData();
    }

    private async Task ResetFilters()
    {
        currentDate = DateTime.Now;
        targetMonthString = currentDate.ToString("yyyy-MM");
        targetYear = currentDate.Year;
        selectedCategory = "All";
        viewMode = ViewScope.Monthly;
        await LoadDashboardData();
    }

    private async Task LoadDashboardData()
    {
        isLoading = true;
        StateHasChanged();

        chartData.Clear();
        using var db = await DbFactory.CreateDbContextAsync();

        // 1. DYNAMIC INCOME CAP CALCULATION - AGORA FILTRADO
        var activeSalariesSum = await db.Salaries
            .AsNoTracking()
            .Where(s => targetUserIds.Contains(s.UserId) && s.IsActive == true)
            .SumAsync(s => s.Amount);

        if (viewMode == ViewScope.Monthly)
        {
            currentActiveSalaryLimit = activeSalariesSum;
        }
        else
        {
            currentActiveSalaryLimit = activeSalariesSum * 12;
        }

        // 2. EXPENSE QUERIES - AGORA FILTRADO PELOS ALVOS
        var query = db.Expenses.AsNoTracking().Where(e => targetUserIds.Contains(e.UserId));

        if (viewMode == ViewScope.Monthly)
        {
            var startOfMonth = new DateTime(currentDate.Year, currentDate.Month, 1);
            var endOfMonth = new DateTime(currentDate.Year, currentDate.Month, DateTime.DaysInMonth(currentDate.Year, currentDate.Month));

            query = query.Where(e =>
                (!e.IsRecurring && e.Date.Year == currentDate.Year && e.Date.Month == currentDate.Month) ||
                (e.IsRecurring && e.Date <= endOfMonth && (e.EndDate == null || e.EndDate >= startOfMonth))
            );
        }
        else
        {
            var startOfYear = new DateTime(targetYear, 1, 1);
            var endOfYear = new DateTime(targetYear, 12, 31);

            query = query.Where(e =>
                (!e.IsRecurring && e.Date.Year == targetYear) ||
                (e.IsRecurring && e.Date <= endOfYear && (e.EndDate == null || e.EndDate >= startOfYear))
            );
        }

        if (selectedCategory != "All")
        {
            query = query.Where(e => e.Category == selectedCategory);
        }

        var filteredExpenses = await query.ToListAsync();

        if (filteredExpenses.Any())
        {
            if (viewMode == ViewScope.Monthly)
            {
                var dailyGroups = new Dictionary<int, float>();
                int daysInMonth = DateTime.DaysInMonth(currentDate.Year, currentDate.Month);

                for (int d = 1; d <= daysInMonth; d++)
                {
                    var evaluationDay = new DateTime(currentDate.Year, currentDate.Month, d);
                    float daySum = 0;

                    foreach (var exp in filteredExpenses)
                    {
                        if (exp.IsRecurring)
                        {
                            if (exp.Date <= evaluationDay && (exp.EndDate == null || exp.EndDate >= evaluationDay))
                            {
                                int targetDay = Math.Min(exp.Date.Day, daysInMonth);
                                if (d == targetDay)
                                {
                                    daySum += exp.Total;
                                }
                            }
                        }
                        else if (exp.Date.Day == d)
                        {
                            daySum += exp.Total;
                        }
                    }
                    if (daySum != 0) dailyGroups[d] = daySum;
                }
                chartData = dailyGroups;
            }
            else
            {
                var yearlyGroups = new Dictionary<int, float>();
                for (int m = 1; m <= 12; m++)
                {
                    float monthSum = 0;
                    var monthEvaluationStart = new DateTime(targetYear, m, 1);
                    var monthEvaluationEnd = new DateTime(targetYear, m, DateTime.DaysInMonth(targetYear, m));

                    foreach (var exp in filteredExpenses)
                    {
                        if (exp.IsRecurring)
                        {
                            if (exp.Date <= monthEvaluationEnd && (exp.EndDate == null || exp.EndDate >= monthEvaluationStart))
                            {
                                monthSum += exp.Total;
                            }
                        }
                        else if (exp.Date.Month == m)
                        {
                            monthSum += exp.Total;
                        }
                    }
                    if (monthSum != 0) yearlyGroups[m] = monthSum;
                }
                chartData = yearlyGroups;
            }

            maxChartSpend = chartData.Values.Any() ? chartData.Values.Select(v => Math.Abs(v)).Max() : 0;

            if (selectedCategory == "All" && currentActiveSalaryLimit > maxChartSpend)
            {
                maxChartSpend = currentActiveSalaryLimit;
            }

            periodTotal = chartData.Values.Sum();

            if (viewMode == ViewScope.Monthly)
            {
                int daysPassed = isCurrentPeriod ? Math.Max(1, DateTime.Now.Day) : totalBars;
                if (currentDate > DateTime.Now) daysPassed = totalBars;
                periodAverage = periodTotal / daysPassed;
            }
            else
            {
                int monthsPassed = isCurrentPeriod ? Math.Max(1, DateTime.Now.Month) : 12;
                if (targetYear > DateTime.Now.Year) monthsPassed = 12;
                periodAverage = periodTotal / monthsPassed;
            }

            if (selectedCategory == "All")
            {
                dynamicTopMetric = filteredExpenses
                    .GroupBy(e => e.Category)
                    .OrderByDescending(g => g.Sum(e => Math.Abs(e.Total)))
                    .Select(g => g.Key)
                    .FirstOrDefault() ?? "None";
            }
            else
            {
                dynamicTopMetric = filteredExpenses
                    .GroupBy(e => e.Place)
                    .OrderByDescending(g => g.Sum(e => Math.Abs(e.Total)))
                    .Select(g => g.Key)
                    .FirstOrDefault() ?? "None";
            }
        }
        else
        {
            maxChartSpend = selectedCategory == "All" ? currentActiveSalaryLimit : 0;
            periodTotal = 0;
            periodAverage = 0;
            dynamicTopMetric = "None";
        }

        await LoadAvailableCategories();
        isLoading = false;
        StateHasChanged();
    }
}