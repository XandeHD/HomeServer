@page "/finance/load-expenses"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using System.Text
@using System.Text.Json
@using System.Security.Claims
@inject IHttpClientFactory ClientFactory
@inject IConfiguration Configuration
@inject IDbContextFactory<DataContext> DbFactory
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Load Expenses</PageTitle>

<InputFile id="expenseReceiptInput" OnChange="HandleReceiptSelected" class="d-none" accept="image/*" capture="environment" />

@* Header Section *@
<div class="d-flex justify-content-between align-items-end mb-3">
    <div>
        <h1 class="h4 text-dark fw-semibold mb-0">Load Expenses</h1>
        <p class="text-muted small mb-0">Track detailed itemizations for restaurants, retail, fixed bills, and general purchases.</p>

        @* NOVO: Indicador visual do Contexto Atual (Solo vs Grupo) *@
        <div class="mt-2">
            @if (hasGroup)
            {
                <span class="badge bg-success d-inline-flex align-items-center gap-1">
                    <i class="bi bi-people-fill"></i> Grupo Ativo (ID: @userGroupId)
                </span>
            }
            else
            {
                <span class="badge bg-secondary d-inline-flex align-items-center gap-1">
                    <i class="bi bi-person-fill"></i> Modo Solo
                </span>
            }
        </div>
    </div>

    <div class="d-flex gap-2">
        <button class="btn btn-sm btn-outline-primary @(currentFilterMode == FilterMode.All ? "active" : "")" @onclick="LoadExpensesFromDatabase">All</button>
        <button class="btn btn-sm btn-outline-primary @(currentFilterMode == FilterMode.Recurring ? "active" : "")" @onclick="LoadRecurringExpenses">Monthly Only</button>
    </div>

    <div class="d-flex gap-2">
        <label for="expenseReceiptInput" class="btn btn-sm btn-outline-secondary d-inline-flex align-items-center gap-1 px-2.5 py-1.5 shadow-sm style-pointer">
            <i class="bi bi-camera"></i>
            <span class="small fw-medium">Scan Receipt</span>
        </label>

        <button type="button" class="btn btn-sm btn-primary d-inline-flex align-items-center gap-1 px-2.5 py-1.5 shadow-sm" @onclick="OpenAddModal">
            <i class="bi bi-plus-lg small"></i>
            <span class="small fw-medium">New Expense</span>
        </button>
    </div>
</div>

@* Date Filter Bar Section *@
<div class="card p-3 mb-3 bg-white shadow-sm border border-light rounded">
    <div class="row g-2 align-items-end">
        <div class="col-sm-4">
            <label class="form-label small fw-medium text-secondary mb-1">Start Date</label>
            <input type="date" @bind="FilterStartDate" class="form-control form-control-sm" />
        </div>
        <div class="col-sm-4">
            <label class="form-label small fw-medium text-secondary mb-1">End Date (Empty = Forever)</label>
            <input type="date" @bind="FilterEndDate" class="form-control form-control-sm" />
        </div>
        <div class="col-sm-4 d-flex gap-2">
            <button class="btn btn-sm btn-primary flex-grow-1" @onclick="ApplyFilters">
                <i class="bi bi-filter me-1"></i> Filter
            </button>
            <button class="btn btn-sm btn-light border" @onclick="ClearFilters">
                Clear
            </button>
        </div>
    </div>
</div>

@* Compact Loading Animation Bar *@
@if (isLoading)
{
    <div class="d-flex align-items-center gap-3 my-3 p-3 border-0 rounded-3 shadow-sm position-relative overflow-hidden"
         style="background: linear-gradient(135deg, #f0f7ff 0%, #f9f5ff 100%); max-width: 450px;">
        <div class="position-absolute top-0 start-0 w-100" style="height: 3px; background: linear-gradient(90deg, #0d6efd, #9b51e0, #0d6efd); background-size: 200% auto; animation: gradientMove 2s linear infinite;"></div>
        <div class="spinner-grow text-primary flex-shrink-0" role="status" style="width: 1.8rem; height: 1.8rem;"></div>
        <div class="flex-grow-1">
            <h6 class="text-dark fw-bold mb-0 d-flex align-items-center gap-2">
                Processing Receipt
                <span class="badge rounded-pill bg-purple-light text-purple small fw-normal px-2 py-1" style="background-color: #f3e8ff; color: #6b21a8; font-size: 0.75rem;">AI Syncing</span>
            </h6>
            <p class="text-secondary small mb-0" style="font-size: 0.825rem;">Gemini is parsing line entries and total metrics...</p>
        </div>
    </div>
}

@* Main Expense History Log Table *@
@if (expensesHistory == null)
{
    <p class="text-muted small"><em>Loading expense history...</em></p>
}
else if (!expensesHistory.Any())
{
    <p class="text-muted bg-white p-4 rounded shadow-sm text-center small border">No items recorded yet.</p>
}
else
{
    <table class="table table-hover align-middle border-top border-light shadow-sm bg-white rounded">
        <thead class="table-light text-secondary small text-uppercase tracking-wider">
            <tr>
                <th class="ps-3">Place / Business</th>
                <th>Category</th>
                <th>Details / Items</th>
                <th class="text-center" style="width: 140px;">Date</th>
                <th class="text-end" style="width: 120px;">Total</th>
                <th class="text-end pe-3" style="width: 160px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var exp in expensesHistory)
            {
                <tr class="@(deleteTargetId == exp.Id ? "table-danger-light" : "")">
                    <td class="ps-3 fw-semibold text-dark">
                        @exp.Place
                        @if (exp.IsRecurring)
                        {
                            <i class="bi bi-arrow-counterclockwise text-primary ms-1 small" title="Monthly Recurring Expense"></i>
                        }
                    </td>
                    <td><span class="badge bg-light text-dark border px-2 py-1 small fw-normal">@exp.Category</span></td>
                    <td class="text-secondary small">
                        @if (exp.Lines != null && exp.Lines.Any())
                        {
                            <span class="text-primary fw-medium">@exp.Lines.Count items</span>
                            <span class="text-muted text-xs">(@string.Join(", ", exp.Lines.Take(2).Select(l => l.Description))...)</span>
                        }
                        else
                        {
                            <span>@(string.IsNullOrWhiteSpace(exp.Description) ? "---" : exp.Description)</span>
                        }
                    </td>
                    <td class="text-center text-muted small">@exp.Date.ToString("dd-MM-yyyy")</td>
                    <td class="text-end fw-bold text-dark">€@exp.Total.ToString("F2")</td>
                    <td class="text-end pe-3">
                        <div class="d-inline-flex align-items-center gap-2">
                            @if (deleteTargetId == exp.Id)
                            {
                                <div class="btn-group btn-group-sm shadow-sm border border-danger rounded overflow-hidden">
                                    <button type="button" class="btn btn-danger px-2" @onclick="() => ConfirmDelete(exp.Id)">
                                        <i class="bi bi-trash-fill me-1"></i> Delete
                                    </button>
                                    <button type="button" class="btn btn-light px-2 text-muted" @onclick="CancelDelete"><i class="bi bi-x-lg"></i></button>
                                </div>
                            }
                            else
                            {
                                <button type="button" class="btn btn-sm btn-link text-secondary text-decoration-none p-1 small me-1" @onclick="() => OpenEditModal(exp)">
                                    <i class="bi bi-pencil-square"></i> Edit
                                </button>
                                <button type="button" class="btn btn-sm btn-link text-danger text-decoration-none p-1 small" @onclick="() => RequestDelete(exp.Id)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@* Unified Dialog Modal Management Block *@
@if (IsVisible)
{
    <div class="modal fade show d-block" style="background-color: rgba(15, 23, 42, 0.4); backdrop-filter: blur(4px);" @onclick="CloseModal">
        <div class="modal-dialog modal-dialog-centered modal-lg" @onclick:stopPropagation="true" style="max-width: 680px;">
            <div class="modal-content border-0 shadow-lg rounded-3">
                <div class="modal-header bg-light border-bottom-0 py-3 px-4">
                    <h5 class="modal-title fw-bold text-dark fs-6">
                        @((currentExpense.Id == 0) ? "Register New Expense" : "Modify Expense Entry")
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body px-4 py-3" style="max-height: 80vh; overflow-y: auto;">
                    <EditForm Model="@currentExpense" OnValidSubmit="@SaveExpense">
                        <DataAnnotationsValidator />

                        <div class="row g-2 mb-2">
                            <div class="col-sm-4">
                                <label class="form-label small fw-medium text-secondary mb-1">Place / Business *</label>
                                <InputText @bind-Value="currentExpense.Place" class="form-control form-control-sm" placeholder="Business Name" />
                            </div>
                            <div class="col-sm-4">
                                <label class="form-label small fw-medium text-secondary mb-1">Date *</label>
                                <InputDate @bind-Value="currentExpense.Date" class="form-control form-control-sm" />
                            </div>
                            <div class="col-sm-4">
                                <label class="form-label small fw-medium text-secondary mb-1">Category *</label>
                                <InputSelect @bind-Value="currentExpense.Category" class="form-control form-control-sm">
                                    <option value="Restaurant">Restaurant / Cafe</option>
                                    <option value="Shopping">Shopping (Non-Food)</option>
                                    <option value="Transport">Transport / Fuel</option>
                                    <option value="Medic">Medic</option>
                                    <option value="Pharmacy">Pharmacy</option>
                                    <option value="Games">Games</option>
                                    <option value="Clothes">Clothes</option>
                                    <option value="Technology">Technology</option>
                                    <option value="Home">Home</option>
                                    <option value="Savings">Savings</option>
                                    <option value="Other">Other Services</option>
                                </InputSelect>
                            </div>
                        </div>

                        <div class="row g-2 mb-3 align-items-end">
                            <div class="col-sm-6">
                                <label class="form-label small fw-medium text-secondary mb-1">General Context / Notes</label>
                                <InputText @bind-Value="currentExpense.Description" class="form-control form-control-sm" placeholder="Overall entry details..." />
                            </div>
                            <div class="col-sm-3">
                                <div class="form-check form-switch bg-white border rounded d-flex align-items-center justify-content-start gap-2 shadow-sm" style="height: 31px; padding-left: 2.75rem;">
                                    <InputCheckbox @bind-Value="currentExpense.IsRecurring" class="form-check-input style-pointer m-0" id="isRecurringCheck" style="margin-left: -2rem !important;" />
                                    <label class="form-check-label small fw-semibold text-dark style-pointer select-none mb-0 text-nowrap" for="isRecurringCheck">Monthly Bill</label>
                                </div>
                            </div>
                            <div class="col-sm-3">
                                <label class="form-label small fw-medium text-danger mb-1">End Date (Optional)</label>
                                <InputDate @bind-Value="currentExpense.EndDate" class="form-control form-control-sm border-danger text-danger" />
                            </div>
                        </div>

                        @* Itemized Line Breakdown Section *@
                        <div class="border rounded p-3 bg-light mb-3">
                            <h6 class="fw-bold text-dark mb-2 small d-flex justify-content-between align-items-center">
                                <span><i class="bi bi-list-ul me-1 text-primary"></i> Itemized Line Details</span>
                                <span class="text-muted fw-normal font-monospace text-xs">Total from lines: €@LineItemSum.ToString("F2")</span>
                            </h6>

                            <table class="table table-sm align-middle bg-white rounded border mb-2">
                                <thead class="table-light text-secondary font-monospace" style="font-size: 0.75rem;">
                                    <tr>
                                        <th class="ps-2">Description / Consumed Item</th>
                                        <th class="text-center" style="width: 80px;">Qty</th>
                                        <th class="text-end" style="width: 100px;">Price (€)</th>
                                        <th class="text-end" style="width: 100px;">Total</th>
                                        <th class="text-center" style="width: 50px;"></th>
                                    </tr>
                                </thead>
                                <tbody style="font-size: 0.825rem;">
                                    @if (currentExpense.Lines == null || !currentExpense.Lines.Any())
                                    {
                                        <tr>
                                            <td colspan="5" class="text-center text-muted py-2 small">No items added yet. Enter items below or verify totals manually.</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        @foreach (var line in currentExpense.Lines)
                                        {
                                            <tr>
                                                <td class="ps-2 fw-medium">@line.Description</td>
                                                <td class="text-center">@line.Quantity</td>
                                                <td class="text-end">€@line.Price.ToString("F2")</td>
                                                <td class="text-end fw-semibold text-secondary">€@((line.Quantity * line.Price).ToString("F2"))</td>
                                                <td class="text-center">
                                                    <button type="button" class="btn btn-xs p-0 text-danger border-0 bg-transparent" @onclick="() => RemoveLineItem(line)">
                                                        <i class="bi bi-dash-circle-fill"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>

                            <div class="row g-1 align-items-center">
                                <div class="col-6">
                                    <input type="text" @bind="newLineDescription" class="form-control form-control-sm" placeholder="e.g., Hamburger, T-Shirt, Fuel Load" />
                                </div>
                                <div class="col-2">
                                    <input type="number" @bind="newLineQty" class="form-control form-control-sm text-center" step="0.1" placeholder="Qty" />
                                </div>
                                <div class="col-3">
                                    <input type="number" @bind="newLinePrice" class="form-control form-control-sm text-end" step="0.01" placeholder="Price €" />
                                </div>
                                <div class="col-1 text-center">
                                    <button type="button" class="btn btn-sm btn-secondary w-100" @onclick="AddLineItemInline">
                                        <i class="bi bi-plus-lg"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="row align-items-center pt-2">
                            <div class="col-6">
                                <div class="d-flex align-items-center gap-2">
                                    <label class="form-label small fw-bold text-dark mb-0 text-nowrap">Final Total Cost (€) *</label>
                                    <InputNumber @bind-Value="currentExpense.Total" class="form-control form-control-sm text-end fw-bold text-primary" style="max-width: 130px;" step="0.01" />
                                </div>
                            </div>
                            <div class="col-6 d-flex justify-content-end gap-2">
                                <button type="button" class="btn btn-sm btn-light border" @onclick="CloseModal">Cancel</button>
                                <button type="submit" class="btn btn-sm btn-primary px-3">
                                    @((currentExpense.Id == 0) ? "Save Expense" : "Update Changes")
                                </button>
                            </div>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Expense>? expensesHistory;
    private Expense currentExpense { get; set; } = new() { Lines = new List<ExpenseLine>() };

    private string newLineDescription = "";
    private float newLineQty = 1;
    private float newLinePrice = 0;

    private bool IsVisible { get; set; } = false;
    private bool isLoading = false;
    private int deleteTargetId = 0;

    // NOVO: Propriedades para controlo de Contexto e Sessão
    private int loggedUserId;
    private int userGroupId;
    private bool hasGroup = false;

    // Filter properties
    private DateTime? FilterStartDate { get; set; }
    private DateTime? FilterEndDate { get; set; }
    private FilterMode currentFilterMode = FilterMode.All;

    private enum FilterMode { All, Recurring }

    private float LineItemSum => currentExpense.Lines?.Sum(l => l.Price * l.Quantity) ?? 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadUserSessionData();
        await FetchData();
    }

    // NOVO: Lê os dados do Cookie de autenticação gerados no Login
    private async Task LoadUserSessionData()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            // Extrai o ID do Utilizador
            var userIdStr = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (int.TryParse(userIdStr, out int userId))
            {
                loggedUserId = userId;
            }

            // Extrai o ID do Grupo (se existir)
            var groupIdStr = user.FindFirst(ClaimTypes.GroupSid)?.Value;
            if (!string.IsNullOrEmpty(groupIdStr) && int.TryParse(groupIdStr, out int groupId))
            {
                userGroupId = groupId;
                hasGroup = true;
            }
        }
    }

    private async Task FetchData()
    {
        if (loggedUserId == 0) return; // Utilizador não autenticado de forma válida

        using var db = await DbFactory.CreateDbContextAsync();

        // Iniciamos a query incluindo os sub-itens das linhas
        var query = db.Expenses.Include(e => e.Lines).AsQueryable();

        // MODIFICAÇÃO PRINCIPAL: Regra Solo vs Grupo
        if (hasGroup)
        {
            // MODO GRUPO: Carrega despesas cujo UserId pertença à lista de membros do grupo ativo
            var membrosDoGrupo = db.GroupUsers
                .Where(gu => gu.GroupId == userGroupId)
                .Select(gu => gu.UserId);

            query = query.Where(e => membrosDoGrupo.Contains(e.UserId));
        }
        else
        {
            // MODO SOLO: Carrega estritamente as despesas do utilizador logado
            query = query.Where(e => e.UserId == loggedUserId);
        }

        // Aplicar o filtro de visualização principal (Tudo vs Apenas Recorrentes)
        if (currentFilterMode == FilterMode.Recurring)
        {
            query = query.Where(e => e.IsRecurring == true);
        }

        // Aplicar filtros de intervalo de datas dinâmicos
        if (FilterStartDate.HasValue)
        {
            query = query.Where(e => e.Date >= FilterStartDate.Value);
        }

        if (FilterEndDate.HasValue)
        {
            query = query.Where(e => e.Date <= FilterEndDate.Value);
        }

        expensesHistory = await query.OrderByDescending(e => e.Date).ToListAsync();
    }

    private async Task LoadExpensesFromDatabase()
    {
        currentFilterMode = FilterMode.All;
        await FetchData();
    }

    private async Task LoadRecurringExpenses()
    {
        currentFilterMode = FilterMode.Recurring;
        await FetchData();
    }

    private async Task ApplyFilters()
    {
        await FetchData();
    }

    private async Task ClearFilters()
    {
        FilterStartDate = null;
        FilterEndDate = null;
        await FetchData();
    }

    private void OpenAddModal()
    {
        currentExpense = new Expense
        {
            Date = DateTime.Now,
            Category = "Restaurant",
            IsRecurring = false,
            UserId = loggedUserId, // NOVO: Garante o vínculo da nova despesa ao utilizador logado
            Lines = new List<ExpenseLine>()
        };
        ResetLineInputs();
        IsVisible = true;
    }

    private void OpenEditModal(Expense target)
    {
        currentExpense = new Expense
        {
            Id = target.Id,
            UserId = target.UserId, // Mantém o dono original
            Place = target.Place,
            Description = target.Description,
            Date = target.Date,
            EndDate = target.EndDate,
            Total = target.Total,
            Category = target.Category,
            IsRecurring = target.IsRecurring,
            Lines = target.Lines != null
                ? target.Lines.Select(l => new ExpenseLine { Id = l.Id, ExpenseId = l.ExpenseId, Description = l.Description, Quantity = l.Quantity, Price = l.Price }).ToList()
                : new List<ExpenseLine>()
        };
        ResetLineInputs();
        IsVisible = true;
    }

    private void CloseModal() => IsVisible = false;

    private void AddLineItemInline()
    {
        if (string.IsNullOrWhiteSpace(newLineDescription) || newLinePrice <= 0) return;

        if (currentExpense.Lines == null) currentExpense.Lines = new List<ExpenseLine>();

        currentExpense.Lines.Add(new ExpenseLine
        {
            Description = newLineDescription,
            Quantity = newLineQty,
            Price = newLinePrice
        });

        currentExpense.Total = LineItemSum;
        ResetLineInputs();
    }

    private void RemoveLineItem(ExpenseLine targetLine)
    {
        currentExpense.Lines?.Remove(targetLine);
        currentExpense.Total = LineItemSum;
    }

    private void ResetLineInputs()
    {
        newLineDescription = "";
        newLineQty = 1;
        newLinePrice = 0;
    }

    private async Task SaveExpense()
    {
        if (currentExpense.Date == default) currentExpense.Date = DateTime.Now;

        using var db = await DbFactory.CreateDbContextAsync();

        if (currentExpense.Id == 0)
        {
            db.Expenses.Add(currentExpense);
            await db.SaveChangesAsync();
        }
        else
        {
            var existingExpense = await db.Expenses.Include(e => e.Lines).FirstOrDefaultAsync(e => e.Id == currentExpense.Id);
            if (existingExpense != null)
            {
                existingExpense.Place = currentExpense.Place;
                existingExpense.Description = currentExpense.Description;
                existingExpense.Date = currentExpense.Date;
                existingExpense.EndDate = currentExpense.EndDate;
                existingExpense.Total = currentExpense.Total;
                existingExpense.Category = currentExpense.Category;
                existingExpense.IsRecurring = currentExpense.IsRecurring;

                if (existingExpense.Lines != null)
                {
                    db.ExpenseLines.RemoveRange(existingExpense.Lines);
                }

                existingExpense.Lines = currentExpense.Lines?.Select(l => new ExpenseLine
                {
                    Description = l.Description,
                    Quantity = l.Quantity,
                    Price = l.Price
                }).ToList() ?? new List<ExpenseLine>();

                await db.SaveChangesAsync();
            }
        }

        CloseModal();
        await FetchData();
    }

    private void RequestDelete(int id) => deleteTargetId = id;
    private void CancelDelete() => deleteTargetId = 0;

    private async Task ConfirmDelete(int expenseId)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        using var transaction = await db.Database.BeginTransactionAsync();
        try
        {
            await db.Database.ExecuteSqlRawAsync("DELETE FROM ExpenseLines WHERE ExpenseId = {0}", expenseId);
            await db.Database.ExecuteSqlRawAsync("DELETE FROM Expenses WHERE Id = {0}", expenseId);
            await transaction.CommitAsync();
        }
        catch (Exception)
        {
            await transaction.RollbackAsync();
        }

        deleteTargetId = 0;
        await FetchData();
    }

    private async Task HandleReceiptSelected(InputFileChangeEventArgs e)
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            var http = ClientFactory.CreateClient();
            using var ms = new MemoryStream();
            await e.File.OpenReadStream(4194304).CopyToAsync(ms);

            var base64Image = Convert.ToBase64String(ms.ToArray());
            var apiKey = Configuration["Gemini:ApiKey"];

            string prompt = @"Extract global information and item breakdowns from this receipt...";

            var requestBody = new { /* ... Mantém-se o corpo do pedido original ... */ };

            // ... Lógica de chamada à API e gravação ...
            // Importante: No objeto criado a partir da AI, lembra-te de fixar:
            // newExpense.UserId = loggedUserId;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"AI Line Execution Failure: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            await FetchData();
            StateHasChanged();
        }
    }
}