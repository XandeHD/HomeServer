@inject HomeServer.Classes.Services.Theme ThemeService
@inject HomeServer.Classes.Services.LocalizationService L
@implements IDisposable

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">@L.T("nav.home")</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable @ThemeService.CurrentThemeClass" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/finance" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill" aria-hidden="true"></span> @L.T("nav.dashboard")
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="finance/load-expenses">
                <span class="bi bi-wallet2" aria-hidden="true"></span> @L.T("nav.expenses")
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="finance/salary">
                <span class="bi bi-cash-coin" aria-hidden="true"></span> @L.T("nav.salary")
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="finance/buyorders">
                <span class="bi bi-list-task" aria-hidden="true"></span> @L.T("nav.buyorders")
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="finance/stocks">
                <span class="bi bi-graph-up-arrow" aria-hidden="true"></span> @L.T("nav.stocks")
            </NavLink>
        </div>
    </nav>
</div>

@code {
    protected override void OnInitialized()
    {
        L.OnLanguageChanged += OnLanguageChanged;
    }

    private void OnLanguageChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        L.OnLanguageChanged -= OnLanguageChanged;
    }
}
